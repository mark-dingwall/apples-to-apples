# Database connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database
DB_USER=your_username
DB_PASSWORD=your_password

# SSH Tunnel Settings (optional)
# Enable SSH tunneling to connect to database through a bastion host
SSH_ENABLED=false
SSH_HOST=bastion.example.com
SSH_PORT=22
SSH_USER=deploy
SSH_KEY_PATH=~/.ssh/id_rsa
# SSH_KEY_PASSPHRASE=your_key_passphrase
# SSH_REMOTE_BIND_HOST=internal-db.vpc
# SSH_REMOTE_BIND_PORT=3306

# Claude model for SWOT analysis (default: sonnet)
# SWOT_MODEL=sonnet
